# Admin Configuration (Required)
ADMIN_EMAIL=admin@example.com
# Set ADMIN_PASSWORD to bcrypt hash (generated from ADMIN_PASSWORD_PLAIN)
# Use ADMIN_PASSWORD_PLAIN to generate hash on startup, then copy the hash to ADMIN_PASSWORD
ADMIN_PASSWORD=$2b$12$T9wq/nWwEr51F80QclO1guB2rSIU8EpkWago4mp7DWF0nhUMJnxJa
# To generate a new password hash, set ADMIN_PASSWORD_PLAIN=your-password and restart
# The hash will be printed to console, then copy it to ADMIN_PASSWORD
ADMIN_PASSWORD_PLAIN=

# JWT Configuration (Required in production)
# Generate a secure random key: python -c "from jose import jwt; import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=sqlite:///./data/gateway.db

# Server
HOST=0.0.0.0
PORT=8000

# Encryption (32-byte key for Fernet/AES-256)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-encryption-key

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_MINUTES=1

# Timestamp tolerance for HyperBEAM signatures (seconds)
TIMESTAMP_TOLERANCE_SECONDS=300

# Environment (development or production)
ENVIRONMENT=development
